# FinPilot AI - Environment Configuration Example
# ==================================================
# Copy this file as .env and update values for your environment.

# Application Settings
APP_NAME=FinPilot AI
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=8000

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Future AI/LLM Configuration
# OPENAI_API_KEY=your-api-key-here
# OPENAI_MODEL=gpt-4

# Future Database Configuration
# DATABASE_URL=sqlite:///./finpilot.db
