generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

 datasource db {
   provider = "postgresql"
   // connection URLs are provided via prisma.config.ts
 }

// Financial models
model AuthUser {
  id          String   @id @default(uuid())
  profiles    Profile[]
  expenses    Expense[]
  budgets     Budget[]
  goals       Goal[]
  emiPlanners EMIPlanner[]
  transactions Transaction[]
  @@map("auth.users")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  fullName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      AuthUser @relation(fields: [userId], references: [id])
  @@map("profiles")
}

model Expense {
  id          String   @id @default(uuid())
  userId      String
  amount      Decimal
  category    String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        AuthUser @relation(fields: [userId], references: [id])
  @@map("expenses")
}

model Budget {
  id        String   @id @default(uuid())
  userId    String
  total     Decimal
  period    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      AuthUser @relation(fields: [userId], references: [id])
  @@map("budgets")
}

model Goal {
  id            String   @id @default(uuid())
  userId        String
  title         String
  targetAmount  Decimal
  currentAmount Decimal @default(0)
  deadline      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          AuthUser @relation(fields: [userId], references: [id])
  @@map("goals")
}

model EMIPlanner {
  id          String   @id @default(uuid())
  userId      String
  loanAmount  Decimal
  annualRate  Decimal
  tenureMonths Int
  startDate   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        AuthUser @relation(fields: [userId], references: [id])
  @@map("emi_planners")
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  type        String
  amount      Decimal
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        AuthUser @relation(fields: [userId], references: [id])
  @@map("transactions")
}
